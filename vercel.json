{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/article.html", "destination": "/article.html" },
    { "source": "/home.html", "destination": "/home.html" },
    { "source": "/recruit.html", "destination": "/recruit.html" },
    { "source": "/join.html", "destination": "/join.html" },
    { "source": "/team-blog.html", "destination": "/team-blog.html" },
    { "source": "/team-article.html", "destination": "/team-article.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
