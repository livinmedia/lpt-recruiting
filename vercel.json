{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "all" }
      ]
    }
  ],
  "routes": [
    { "src": "^/og/(.*)", "dest": "/og/$1" },
    { "src": "^/assets/(.*)", "dest": "/assets/$1" },
    { "src": "^/(.*\\.(?:png|jpg|jpeg|gif|svg|ico|css|js|woff|woff2|ttf|eot|webp|mp4|pdf))$", "dest": "/$1" },
    { "src": "^/$", "dest": "/home.html" },
    { "src": "^/home$", "dest": "/home.html" },
    { "src": "^/login$", "dest": "/login.html" },
    { "src": "^/signup$", "dest": "/signup.html" },
    { "src": "^/join$", "dest": "https://usknntguurefeyzusbdh.supabase.co/functions/v1/serve-landing?page=join&ref=$query(ref)", "check": true },
    { "src": "^/calculator$", "dest": "https://usknntguurefeyzusbdh.supabase.co/functions/v1/serve-landing?page=calculator&ref=$query(ref)", "check": true },
    { "src": "^/new-agent$", "dest": "https://usknntguurefeyzusbdh.supabase.co/functions/v1/serve-landing?page=new-agent&ref=$query(ref)", "check": true },
    { "src": "^/revenue-share$", "dest": "https://usknntguurefeyzusbdh.supabase.co/functions/v1/serve-landing?page=revenue-share&ref=$query(ref)", "check": true },
    { "src": "^/why-switch$", "dest": "https://usknntguurefeyzusbdh.supabase.co/functions/v1/serve-landing?page=why-switch&ref=$query(ref)", "check": true },
    { "src": "^/robots\\.txt$", "dest": "/robots.txt" },
    { "src": "^/app(/.*)?$", "dest": "/index.html" },
    { "src": "^/(.*)$", "dest": "/home.html" }
  ]
}
