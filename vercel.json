{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "all" }
      ]
    }
  ],
  "routes": [
    { "src": "^/og/(.*)", "dest": "/og/$1" },
    { "src": "^/assets/(.*)", "dest": "/assets/$1" },
    { "src": "^/(.*\\.(?:png|jpg|jpeg|gif|svg|ico|css|js|woff|woff2|ttf|eot|webp|mp4|pdf))$", "dest": "/$1" },
    { "src": "^/login$", "dest": "/login.html" },
    { "src": "^/signup$", "dest": "/signup.html" },
    { "src": "^/(.*)", "has": [{ "type": "host", "value": "app.rkrt.in" }], "dest": "/index.html" },
    { "src": "^/$", "dest": "/home.html" },
    { "src": "^/home$", "dest": "/home.html" },
    { "src": "^/join$", "dest": "/join.html" },
    { "src": "^/calculator$", "dest": "/calculator.html" },
    { "src": "^/new-agent$", "dest": "/new-agent.html" },
    { "src": "^/revenue-share$", "dest": "/revenue-share.html" },
    { "src": "^/why-switch$", "dest": "/why-switch.html" },
    { "src": "^/robots\\.txt$", "dest": "/robots.txt" },
    { "src": "^/app(/.*)?$", "dest": "/index.html" },
    { "src": "^/(.*)$", "dest": "/home.html" }
  ]
}
