{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "routes": [
    { "src": "^/og/(.*)", "dest": "/og/$1" },
    { "src": "^/assets/(.*)", "dest": "/assets/$1" },
    { "src": "^/(.*\\.(?:png|jpg|jpeg|gif|svg|ico|css|js|woff|woff2|ttf|eot|webp|mp4|pdf))$", "dest": "/$1" },
    { "src": "^/$", "dest": "/home.html" },
    { "src": "^/home$", "dest": "/home.html" },
    { "src": "^/login$", "dest": "/login.html" },
    { "src": "^/signup$", "dest": "/signup.html" },
    { "src": "^/join$", "dest": "/join/index.html" },
    { "src": "^/calculator$", "dest": "/calculator/index.html" },
    { "src": "^/new-agent$", "dest": "/new-agent/index.html" },
    { "src": "^/revenue-share$", "dest": "/revenue-share/index.html" },
    { "src": "^/why-switch$", "dest": "/why-switch/index.html" },
    { "src": "^/app(/.*)?$", "dest": "/index.html" }
  ]
}
